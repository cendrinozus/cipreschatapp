# ─── Secrets (OBLIGATOIRE : changer en production) ────────────────────────
SECRET_KEY=change-me-use-a-strong-random-key-in-production
JWT_SECRET_KEY=change-me-jwt-use-a-strong-random-key

# ─── Base de données MySQL ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DB=chatbot_db
MYSQL_USER=chatbot
MYSQL_PASSWORD=chatbot_pass

# ─── Modèles Ollama ────────────────────────────────────────────────────────
OLLAMA_MODEL=mistral-nemo
EMBED_MODEL=nomic-embed-text

# ─── API externe CIPRES (optionnel) ────────────────────────────────────────
EXTERNAL_API_URL=
EXTERNAL_API_TOKEN=
